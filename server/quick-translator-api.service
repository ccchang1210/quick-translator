[Unit]
Description=Quick Translator API
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=infinity
WorkingDirectory=/home/infinity/quick-translator-api
ExecStart=/home/infinity/quick-translator-api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 3030 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
